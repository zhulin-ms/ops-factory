  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "yaml": "^2.8.2"
  }
}
