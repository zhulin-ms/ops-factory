# Gateway runtime configuration
# Spring Boot loads this file directly via GATEWAY_CONFIG_PATH.
# Legacy env var overrides from ctl.sh remain supported for compatibility.

server:
  port: 3000                            # env override: GATEWAY_PORT
  address: "0.0.0.0"                    # env override: GATEWAY_HOST
  ssl:
    enabled: false                      # env override: GATEWAY_TLS
    key-store: "file:.gateway-keystore.p12" # env override: GATEWAY_KEY_STORE
    key-store-password: "changeit"      # env override: GATEWAY_KEY_STORE_PASSWORD
    key-store-type: "PKCS12"

gateway:
  secret-key: ""                        # env override: GATEWAY_SECRET_KEY [REQUIRED]
  cors-origin: "http://127.0.0.1:5173"  # env override: CORS_ORIGIN
  goosed-bin: "goosed"                  # env override: GOOSED_BIN
  goose-tls: true                       # env override: GOOSE_TLS

  paths:
    project-root: ".."                  # env override: PROJECT_ROOT
    agents-dir: "agents"                # env override: AGENTS_DIR
    users-dir: "users"                  # env override: USERS_DIR

  idle:
    timeout-minutes: 15                 # env override: IDLE_TIMEOUT_MINUTES
    check-interval-ms: 60000            # env override: IDLE_CHECK_INTERVAL

  sse:
    first-byte-timeout-sec: 120         # env override: SSE_FIRST_BYTE_TIMEOUT
    idle-timeout-sec: 300               # env override: SSE_IDLE_TIMEOUT
    max-duration-sec: 600               # env override: SSE_MAX_DURATION

  upload:
    max-file-size-mb: 50                # env override: MAX_FILE_SIZE_MB
    max-image-size-mb: 20               # env override: MAX_IMAGE_SIZE_MB

  limits:
    max-instances-per-user: 20          # env override: MAX_INSTANCES_PER_USER
    max-instances-global: 200           # env override: MAX_INSTANCES_GLOBAL

  prewarm:
    enabled: true                       # env override: PREWARM_ENABLED
    default-agent-id: universal-agent   # env override: PREWARM_DEFAULT_AGENT_ID

  logging:
    access-log-enabled: true
    include-upstream-error-body: false
    include-sse-chunk-preview: false
    sse-chunk-preview-max-chars: 160

  # Langfuse observability (optional)
  # env overrides: LANGFUSE_HOST / LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY
  langfuse:
    host: ""
    public-key: ""
    secret-key: ""

  # OnlyOffice preview (optional)
  # env overrides: OFFICE_PREVIEW_ENABLED / ONLYOFFICE_URL / FILE_BASE_URL
  office-preview:
    enabled: false
    onlyoffice-url: ""
    file-base-url: ""

  credential-encryption-key: "changeit-changeit-changeit-32ch"

  remote-execution:
    default-timeout: 30
    max-timeout: 120

logging:
  level:
    root: INFO
    com.huawei.opsfactory.gateway: INFO
    org.springframework: WARN
    reactor: WARN
    io.netty: WARN

residentInstances:
  enabled: true
  entries:
    - userId: admin
      agentIds: ["*"]

agents:
  - {id: universal-agent, name: Universal Agent}
  - {id: fo-copilot, name: FO Copilot}
  - {id: kb-agent, name: KB Agent}
  - {id: report-agent, name: Report Agent}
  - {id: qos-agent, name: QoS Agent}
  - {id: qa-agent, name: QA Agent}
  - {id: qa-cli-agent, name: QA CLI Agent}
  - {id: supervisor-agent, name: Supervisor Agent}
