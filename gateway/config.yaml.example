# Gateway configuration
# Priority: environment variable > config.yaml value > default
# Required fields will cause startup failure if missing from both sources.

port: 3000                              # env: GATEWAY_PORT
host: "0.0.0.0"                         # env: GATEWAY_HOST
secretKey: ""                           # env: GATEWAY_SECRET_KEY     [REQUIRED]
corsOrigin: "http://127.0.0.1:5173"     # env: CORS_ORIGIN
goosedBin: "goosed"                     # env: GOOSED_BIN
goosedTls: true                         # env: GOOSED_TLS  (gateway↔goosed TLS)

paths:
  agentsDir: "agents"                   # env: AGENTS_DIR
  usersDir: "users"                     # env: USERS_DIR

idle:
  timeoutMinutes: 15                    # env: IDLE_TIMEOUT_MINUTES
  checkIntervalMs: 60000               # env: IDLE_CHECK_INTERVAL

sse:
  firstByteTimeoutSec: 120             # env: SSE_FIRST_BYTE_TIMEOUT  (no data at all → recycle)
  idleTimeoutSec: 300                  # env: SSE_IDLE_TIMEOUT        (no content but pings OK → error only)
  maxDurationSec: 600                  # env: SSE_MAX_DURATION        (hard ceiling)

upload:
  maxFileSizeMb: 50                     # env: MAX_FILE_SIZE_MB
  maxImageSizeMb: 20                    # env: MAX_IMAGE_SIZE_MB

limits:
  maxInstancesPerUser: 5               # env: MAX_INSTANCES_PER_USER
  maxInstancesGlobal: 200              # env: MAX_INSTANCES_GLOBAL

prewarm:
  enabled: true                         # env: PREWARM_ENABLED
  defaultAgentId: universal-agent       # env: PREWARM_DEFAULT_AGENT_ID

residentInstances:
  enabled: true
  entries:
    - userId: admin
      agentIds: ["*"]
    - userId: robby
      agentIds: ["*"]

agents:
  - {id: universal-agent, name: Universal Agent}
  - {id: kb-agent, name: KB Agent}
  - {id: report-agent, name: Report Agent}
  - {id: supervisor-agent, name: Supervisor Agent}

# Langfuse observability (optional)
# langfuse:
#   host: ""                            # env: LANGFUSE_HOST
#   publicKey: ""                       # env: LANGFUSE_PUBLIC_KEY
#   secretKey: ""                       # env: LANGFUSE_SECRET_KEY

# OnlyOffice preview (optional)
# officePreview:
#   enabled: false                      # env: OFFICE_PREVIEW_ENABLED
#   onlyofficeUrl: ""                   # env: ONLYOFFICE_URL
#   fileBaseUrl: ""                     # env: FILE_BASE_URL
